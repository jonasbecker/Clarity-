# Supabase-Verbindung.
# 1. Kopiere diese Datei zu ".env.local"  (cp .env.example .env.local)
# 2. Trage deine Werte ein: Supabase-Dashboard → Project Settings → API
#    - "Project URL"        → VITE_SUPABASE_URL
#    - "anon public" key    → VITE_SUPABASE_ANON_KEY
# 3. Dev-Server neu starten (npm run dev), damit die Werte geladen werden.
#
# Diese zwei Werte sind öffentlich (kein Geheimnis). Die Sicherheit kommt
# aus Row Level Security in der Datenbank, nicht aus Geheimhaltung.

VITE_SUPABASE_URL=https://dein-projekt.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-key
